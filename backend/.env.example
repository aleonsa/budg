APP_ENV=development
PORT=8080
LOG_LEVEL=info

# 1. Crea una contraseña segura (sin caracteres especiales extraños) para la API
BUDG_API_PASSWORD=

# 2. Connection string "Transaction" (puerto 6543) para la aplicacion
# Usa el usuario: budg_api.[tu-ref]
# Usa el password: el que pongas en BUDG_API_PASSWORD
# Desarrollo local en macOS: agrega ?sslmode=require al final
# Produccion (Linux): la app exige ?sslmode=verify-full
DATABASE_URL=

# 3. Connection string "Session" (puerto 6543) para migraciones y bootstrap
# Usa el usuario: postgres.[tu-ref]
# Usa el password: el de tu proyecto Supabase
# Agrega al final: ?pgbouncer=true
MIGRATIONS_DATABASE_URL=

# Supabase Auth public configuration. These are not secrets.
# Copy values from Project Settings -> Auth -> JWT Keys -> Discovery URL.
SUPABASE_JWT_ISSUER=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated

# Comma-separated browser origins allowed to call the API with Authorization.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# OpenAI agent. Leave OPENAI_API_KEY empty to disable agent endpoints.
OPENAI_API_KEY=
AGENT_MODEL=gpt-5.4-nano
AGENT_MAX_STEPS=6
AGENT_MAX_TOOL_CALLS=8
AGENT_TIMEOUT_SECONDS=30
AGENT_MAX_OUTPUT_TOKENS=1200
