APP_ENV=development
PORT=8080
LOG_LEVEL=info

# 1. Crea una contraseña segura (sin caracteres especiales extraños) para la API
BUDG_API_PASSWORD=

# 2. Connection string "Transaction" (puerto 6543) para la aplicacion
# Usa el usuario: budg_api.[tu-ref]
# Usa el password: el que pongas en BUDG_API_PASSWORD
# Desarrollo local en macOS: agrega ?sslmode=require al final
# Produccion (Linux): la app exige ?sslmode=verify-full
DATABASE_URL=

# 3. Connection string "Session" (puerto 6543) para migraciones y bootstrap
# Usa el usuario: postgres.[tu-ref]
# Usa el password: el de tu proyecto Supabase
# Agrega al final: ?pgbouncer=true
MIGRATIONS_DATABASE_URL=
