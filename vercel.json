{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite",
      "installCommand": "sh scripts/vercel-install.sh",
      "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
    },
    "backend": {
      "root": "backend",
      "runtime": "container",
      "entrypoint": "Dockerfile"
    }
  },
  "rewrites": [
    { "source": "/v1/(.*)", "destination": { "service": "backend" } },
    { "source": "/healthz", "destination": { "service": "backend" } },
    { "source": "/readyz", "destination": { "service": "backend" } },
    { "source": "/(.*)", "destination": { "service": "frontend" } }
  ]
}
