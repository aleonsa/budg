# Supabase public client (Project Settings -> API).
# URL + anon key are safe for the browser; never put the service_role key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend API base URL (Go server). Only needed for local dev, and only if
# your Go server isn't on the default http://localhost:8080. Production and
# Preview deployments serve frontend+backend from the same Vercel
# project/domain (see /vercel.json) and default to a same-origin relative
# path automatically -- leave this unset there.
VITE_API_BASE_URL=
